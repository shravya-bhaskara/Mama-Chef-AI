# MamaChef AI Environment Configuration

# Server Port (Use 3000 for Emergent deployment)
PORT=3000
NODE_ENV=production

# Database - PostgreSQL Connection String
# For Neon (free tier): postgresql://[user]:[password]@[endpoint].neon.tech/[dbname]?sslmode=require
# For local: postgresql://localhost:5432/mamachef
DATABASE_URL=

# OpenAI API Configuration (via Replit/Emergent integrations)
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# YouTube Data API v3 (Optional - enables YouTube video links)
# Get key at: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# Google Custom Search API (Optional - enables cooking blog links)
# Get key at: https://developers.google.com/custom-search/v1/overview
# Create Search Engine at: https://programmablesearchengine.google.com/
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=
